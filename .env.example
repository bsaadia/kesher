# Copy to .env for local dev. In Render, set these as environment variables
# on both the web service and the scraper (cron job) — not all vars are
# needed by both, see notes below.

# --- Database (web service + scraper) ---
# Local dev (see docker-compose.yml). On Render, this is provided
# automatically when you attach a Postgres database to the service.
DATABASE_URL=postgresql+psycopg2://tzahal:tzahal@localhost:5432/tzahal_mapper

# --- Telegram / Telethon (scraper only) ---
# From https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
# Leave empty for the first local run — Telethon will prompt for an
# interactive login and print a session string to save here. Once set,
# the scraper can run headlessly (required for Render, since there's no
# interactive terminal there).
TELEGRAM_SESSION_STRING=

# --- Flask (web service only) ---
# Used to sign session cookies. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
